<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Login - Gradly</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@sweetalert2/theme-dark@4/dark.css" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/style1.css">
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark py-3">
        <div class="container">
            <a class="navbar-brand fs-4" href="/students">
                🎓 Gradly
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navMenu">
                <ul class="navbar-nav gap-3 align-items-center">
                    <li class="nav-item">
                        <a class="nav-link text-light" href="/students/register">Register</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-5">
                    
                    <div class="card glass-card p-4 p-md-5 text-center">

                        <h3 class="mb-4">Login</h3>

                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="alert alert-danger"><%= error %></div>
                        <% } %>

                        <form method="POST" action="/students/login">
                            
                            <input class="form-control mb-3"
                                   type="email"
                                   name="email"
                                   value="<%= typeof email !== 'undefined' ? email : '' %>"
                                   placeholder="Email"
                                   required>

                            <input class="form-control mb-4"
                                   type="password"
                                   name="password"
                                   placeholder="Password"
                                   required>

                            <button type="submit" class="btn btn-primary w-100 fw-semibold">Login</button>
                        </form>

                        <div class="text-center mt-3">
                            <a href="/students/register" style="color: #7b2cbf; text-decoration: none;">Register New Account</a>
                        </div>
                        <div class="text-center mt-2">
                            <a href="/students" class="text-muted small">Back to Home</a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>

