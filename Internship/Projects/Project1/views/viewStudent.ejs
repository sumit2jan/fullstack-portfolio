<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Student Profile - Gradly</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body{
        background:#0f172a;
        color:white;
    }

    .profile-img{
        width:120px;
        height:120px;
        border-radius:50%;
        object-fit:cover;
        border:3px solid #e5e7eb;
    }

    .video-card video{
        border-radius:10px;
    }
</style>

</head>

<body>

<nav class="navbar navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/students">🎓 Gradly</a>
        <a href="/students/video-dashboard" class="btn btn-outline-light btn-sm">Back</a>
    </div>
</nav>

<div class="container py-5">
<!-- Profile Section -->

<div class="text-center mb-5">

    <img src="<%= student.image || '/uploads/default.png' %>" 
         class="profile-img mb-3">

    <h3>
        <%= student.firstName %> <%= student.lastName %>
    </h3>

    <p class="text-muted">
        <%= student.email %>
    </p>

</div>
<hr>
<!-- Videos Section -->

<h4 class="mb-4 text-center">Student Videos</h4>

<div class="row">

    <% if (videos && videos.length > 0) { %>

        <% videos.forEach(video => { %>

            <div class="col-md-4 mb-4 video-card">

                <video width="100%" controls>
                    <source src="<%= video.videoUrl %>" type="video/mp4">
                </video>

            </div>

        <% }) %>

    <% } else { %>

        <p class="text-center text-muted">No videos uploaded.</p>

    <% } %>

</div>
</div>

</body>
</html>
