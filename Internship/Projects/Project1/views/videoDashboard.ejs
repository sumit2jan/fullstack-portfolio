<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Video Dashboard - Gradly</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #0f172a;
            color: white;
        }

        .card {
            border-radius: 12px;
        }

        .profile-img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #e5e7eb;
            margin: auto;
        }
    </style>
</head>

<body>
    <div class="container py-5">
        <h2 class="text-center mb-5">🎬 Students Video Dashboard</h2>

        <div class="row">

            <% if (students && students.length> 0) { %>

                <% students.forEach(student=> { %>

                    <div class="col-md-4 mb-4">

                        <div class="card shadow-sm p-4 text-center">

                            <!-- Profile Image -->
                            <img src="<%= student.image %>" alt="Profile Image" class="profile-img mb-3">

                            <!-- Name -->
                            <h5>
                                <%= student.firstName %>
                                    <%= student.lastName %>
                            </h5>

                            <!-- Email -->
                            <p class="text-muted">
                                <%= student.email %>
                            </p>

                            <!-- View Profile -->
                            <a href="/students/view/<%= student._id %>" class="btn btn-primary btn-sm w-100">
                                View Profile
                            </a>

                        </div>

                    </div>

                    <% }) %>

                        <% } else { %>
                            <p class="text-center">No students found.</p>
                            <% } %>

        </div>
    </div>
</body>

</html>