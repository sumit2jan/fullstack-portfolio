<!DOCTYPE html>
<html>

<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container py-5">
    <div class="mb-3">
        <a href="/students/profile" class="btn btn-secondary">
            ← Back to Profile
        </a>
    </div>
    <h2 class="mb-4">Admin Dashboard</h2>
    <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Gender</th>
                    <th>Phone</th>
                    <th>Country</th>
                    <th>Address</th>
                    <th>Hobbies</th>
                    <th>DOB</th>
                    <th>Admin</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                <% students.forEach(student=> { %>
                    <tr>

                        <!-- Basic Student Info -->
                        <td>
                            <%= student.firstName %>
                                <%= student.lastName %>
                        </td>

                        <td>
                            <%= student.email %>
                        </td>

                        <!-- Student Detail Info -->
                        <td>
                            <%= student.detail ? student.detail.gender : "N/A" %>
                        </td>

                        <td>
                            <%= student.detail ? student.detail.phone : "N/A" %>
                        </td>

                        <td>
                            <%= student.detail ? student.detail.country : "N/A" %>
                        </td>

                        <td>
                            <%= student.detail ? student.detail.address : "N/A" %>
                        </td>

                        <td>
                            <%= student.detail ? student.detail.hobbies : "N/A" %>
                        </td>

                        <td>
                            <%= student.detail && student.detail.dob ? new Date(student.detail.dob).toLocaleDateString()
                                : "N/A" %>
                        </td>

                        <!-- Admin -->
                        <td>
                            <%= student.isAdmin ? "Yes" : "No" %>
                        </td>

                        <!-- Action -->
                        <td>
                            <a href="/students/edit/<%= student._id %>" class="btn btn-warning btn-sm">
                                Edit
                            </a>
                        </td>

                    </tr>
                    <% }) %>
            </tbody>
        </table>
    </div>

</body>

</html>