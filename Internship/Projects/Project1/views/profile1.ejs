<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Profile - Gradly</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/css/Profile.css">
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="/students">🎓 Gradly</a>
            <div class="ms-auto">
                <a href="/students/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <section class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-10 col-lg-8">

                    <div class="card glass-card p-4 p-md-5">

                        <div class="text-center mb-5">
                            <div class="mb-3">
                                <span class="profile-icon">👤</span>
                            </div>
                            <h2 class="fw-bold">My Profile</h2>
                            <p class="text-muted small">Student Information System</p>
                        </div>

                        <h6 class="section-title">Personal Details</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="label-custom">First Name</label>
                                <div class="value-custom">
                                    <%= student.firstName %>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Last Name</label>
                                <div class="value-custom">
                                    <%= student.lastName %>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="label-custom">Date of Birth</label>
                                <div class="value-custom">
                                    <%= new Date(student.dob).toDateString() %>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="label-custom">Age</label>
                                <div class="value-custom">
                                    <%= student.age %>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="label-custom">Gender</label>
                                <div class="value-custom">
                                    <%= student.gender %>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="label-custom">Hobbies</label>
                                <div class="value-custom">
                                    <%= student.hobbies %>
                                </div>
                            </div>
                        </div>

                        <hr class="divider">

                        <h6 class="section-title">Contact Information</h6>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="label-custom">Email Address</label>
                                <div class="value-custom">
                                    <%= student.email %>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Phone Number</label>
                                <div class="value-custom">
                                    <%= student.phone %>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Address</label>
                                <div class="value-custom">
                                    <%= student.address %>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Country</label>
                                <div class="value-custom">
                                    <%= student.country %>
                                </div>
                            </div>
                        </div>

                        <hr class="divider">

                        <h6 class="section-title">Identity & Security</h6>
                        <div class="row g-4 mb-5">
                            <div class="col-md-6">
                                <label class="label-custom">PAN Card</label>
                                <div class="value-custom">
                                    <%= student.pan %>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Aadhar Number</label>
                                <div class="value-custom">
                                    <%= student.adhar %>
                                </div>
                            </div>
                            <!-- <div class="col-12">
                                <label class="label-custom">Account Password</label>
                                <div class="value-custom font-monospace text-warning">
                                    <%= student.password %>
                                </div>
                            </div> -->
                        </div>
                        <div class="d-grid gap-2 col-md-6 mx-auto">
                            <a href="/students/edit/<%= student._id %>" class="btn btn-danger py-2 fw-bold">
                                Update
                            </a>
                        </div>
                        <div class="d-grid gap-2 col-md-6 mx-auto">
                            <a href="/students/logout" class="btn btn-danger py-2 fw-bold">
                                Logout
                            </a>
                        </div>

                    </div>

                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <% if (typeof messageType !=='undefined' && messageType==="updateSuccess" ) { %>
        <script>
            Swal.fire({
                icon: "success",
                title: "Profile Updated Successfully!",
                text: "Your changes have been saved.",
                confirmButtonText: "OK",
                confirmButtonColor: "#7b2cbf",
                background: '#19191a',
                color: '#fff'
            }).then(() => {
                window.history.replaceState({}, document.title, "/students/profile");
            });
        </script>
        <% } %>

</body>

</html>