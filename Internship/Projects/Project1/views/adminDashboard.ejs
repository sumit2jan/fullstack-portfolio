<!DOCTYPE html>
<html>

<head>
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="stylesheet" href="/css/admin-dashboard.css">
</head>

<body>

    <div class="glow"></div>

    <div class="container py-5">

        <!-- Header -->
        <!-- <div class="dashboard-header mb-5">
            <div>
                <h1 class="dashboard-title">Admin Dashboard</h1>
                <p class="dashboard-subtitle">
                    Manage users, roles and student information
                </p>
            </div>

            <a href="/students/profile" class="btn btn-back">
                ← Back to Profile
            </a>
        </div> -->

        <div class="dashboard-header mb-5">
            <div class="header-container">
                <div class="header-left">
                    <h1 class="dashboard-title">Admin Dashboard</h1>
                    <div class="subtitle-wrapper">
                        <p class="dashboard-subtitle">Manage users, roles and student information</p>
                        <span class="count-badge">Total: <%= students.length %></span>
                    </div>
                </div>

                <div class="header-right">
                    <div class="stat-box">
                        <span class="stat-label">Active Students</span>
                        <span class="stat-number">
                            <%= students.length %>
                        </span>
                    </div>
                    <a href="/students/profile" class="btn-back-modern">
                        <i class="fas fa-arrow-left"></i> Back to Profile
                    </a>
                </div>
            </div>
        </div>







        <!-- Table Card -->
        <div class="dashboard-card p-4">

            <div class="table-responsive">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Country</th>
                            <th>Address</th>
                            <th>Hobbies</th>
                            <th>DOB</th>
                            <th>Role</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% students.forEach(student=> { %>
                            <tr>
                                <td class="fw-semibold">
                                    <%= student.firstName %>
                                        <%= student.lastName %>
                                </td>

                                <td class="text-muted-light">
                                    <%= student.email %>
                                </td>

                                <td>
                                    <%= student.detail?.gender || "—" %>
                                </td>
                                <td>
                                    <%= student.detail?.phone || "—" %>
                                </td>
                                <td>
                                    <%= student.detail?.country || "—" %>
                                </td>
                                <td>
                                    <%= student.detail?.address || "—" %>
                                </td>
                                <td>
                                    <%= student.detail?.hobbies || "—" %>
                                </td>

                                <td>
                                    <%= student.detail?.dob ? new Date(student.detail.dob).toLocaleDateString() : "—" %>
                                </td>

                                <td>
                                    <span class="role-badge <%= student.isAdmin ? 'admin' : 'user' %>">
                                        <%= student.isAdmin ? "Admin" : "User" %>
                                    </span>
                                </td>

                                <td>
                                    <div class="action-buttons">

                                        <a href="/students/edit/<%= student._id %>" class="btn btn-edit btn-sm">
                                            Edit
                                        </a>

                                        <form action="/students/delete/<%= student._id %>" method="POST">
                                            <button type="submit" class="btn-delete btn-sm"
                                                onclick="return confirm('Are you sure?');">
                                                Delete
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>

                </table>
            </div>
        </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <% if (typeof messageType !=='undefined' && messageType==="studentDeleted" ) { %>
        <script>
            Swal.fire({
                icon: "success",
                title: "Profile delete Successfully!",
                text: "Your changes have been saved.",
                confirmButtonText: "OK",
                confirmButtonColor: "#7b2cbf",
                background: '#19191a',
                color: '#fff'
            }).then(() => {
                window.history.replaceState({}, document.title, "/students/admin/dashboard");
            });
        </script>
        <% } %>
            <% if (typeof messageType !=='undefined' && messageType==="DeleteError" ) { %>
                <script>
                    Swal.fire({
                        icon: "error",
                        title: "Error Deleting User",
                        text: "Error occured Please try again Later",
                        confirmButtonColor: "#7b2cbf",
                        confirmButtonText: "Dashboard",
                        background: '#19191a',
                        color: '#fff'
                    }).then(() => {
                        window.history.replaceState({}, document.title, "/students/admin/dashboard");
                    });
                </script>
                <% } %>


</body>

</html>