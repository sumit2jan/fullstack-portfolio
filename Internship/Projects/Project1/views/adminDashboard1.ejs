<!DOCTYPE html>
<html>

<head>
    <title>Admin Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/admin-dashboard.css">
</head>

<body>

    <div class="glow"></div>

    <div class="container py-5">

        <!-- Header -->
        <div class="dashboard-header mb-5">
            <div>
                <h1 class="dashboard-title">Admin Dashboard</h1>
                <p class="dashboard-subtitle">
                    Manage users, roles and student information
                </p>
            </div>

            <a href="/students/profile" class="btn btn-back">
                ← Back to Profile
            </a>
        </div>

        <!-- Table Card -->
        <div class="dashboard-card p-4">

            <div class="table-responsive">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th>Country</th>
                            <th>Address</th>
                            <th>Hobbies</th>
                            <th>DOB</th>
                            <th>Role</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        <% students.forEach(student => { %>
                            <tr>
                                <td class="fw-semibold">
                                    <%= student.firstName %> <%= student.lastName %>
                                </td>

                                <td class="text-muted-light">
                                    <%= student.email %>
                                </td>

                                <td><%= student.detail?.gender || "—" %></td>
                                <td><%= student.detail?.phone || "—" %></td>
                                <td><%= student.detail?.country || "—" %></td>
                                <td><%= student.detail?.address || "—" %></td>
                                <td><%= student.detail?.hobbies || "—" %></td>

                                <td>
                                    <%= student.detail?.dob 
                                        ? new Date(student.detail.dob).toLocaleDateString()
                                        : "—" %>
                                </td>

                                <td>
                                    <span class="role-badge <%= student.isAdmin ? 'admin' : 'user' %>">
                                        <%= student.isAdmin ? "Admin" : "User" %>
                                    </span>
                                </td>

                                <td class="text-end">
                                    <a href="/students/edit/<%= student._id %>" 
                                       class="btn btn-edit">
                                        Edit
                                    </a>
                                </td>
                                <td class="text-end">
                                    <a href="/students/delete/<%= student._id %>" 
                                       class="btn btn-edit">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>

                </table>
            </div>
        </div>

    </div>

</body>

</html>
