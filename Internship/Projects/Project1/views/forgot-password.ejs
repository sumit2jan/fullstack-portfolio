<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Gradly</title>
    <link rel="stylesheet" href="/css/forgot.css">
</head>
<body>
    <div class="background-glow"></div>
    
    <div class="box">
        <div class="icon-container">
            <svg class="lock-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
        </div>
        
        <h2>Forgot Password?</h2>
        <p>Enter the email address associated with your account and we'll send you a link to reset your password.</p>

        <form method="POST" action="/students/forgot-password">
            <div class="input-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="Enter your email" required autocomplete="email">
            </div>
            
            <button type="submit">Send Reset Link</button>
        </form>

        <a href="/students/login" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to Login
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // EJS variables coming from your Express backend
        const messageType = "<%= typeof messageType !== 'undefined' ? messageType : '' %>";
        const messageText = "<%= typeof messageText !== 'undefined' ? messageText : '' %>";

        if (messageType) {
            const swalConfig = {
                background: '#16161a',
                color: '#ffffff',
                confirmButtonColor: '#7c3aed',
                customClass: { popup: 'gradly-swal-popup' }
            };

            if (messageType === 'success') {
                Swal.fire({
                    ...swalConfig,
                    icon: 'success',
                    title: 'Email Sent!',
                    text: messageText || 'A password reset link has been sent to your email.'
                });
            } else if (messageType === 'error') {
                Swal.fire({
                    ...swalConfig,
                    icon: 'error',
                    title: 'Oops!',
                    text: messageText || 'Something went wrong. Please try again.',
                    confirmButtonColor: '#ef4444' // Red color for errors
                });
            }
        }
    </script>
</body>
</html>