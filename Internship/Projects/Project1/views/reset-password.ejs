<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Gradly</title>
    <link rel="stylesheet" href="/css/resetPass.css">
</head>
<body>
    <div class="background-glow"></div>
    
    <div class="box">
        <div class="icon-container">
            <svg class="key-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
            </svg>
        </div>
        
        <h2>Create New Password</h2>
        <p>Your new password must be different from previous used passwords.</p>

        <form id="resetForm" method="POST" action="/students/reset-password">
            <input type="hidden" name="token" value="<%= token %>">

            <div class="input-group">
                <label for="password">New Password</label>
                <input type="password" id="password" name="password" placeholder="Enter new password" required>
            </div>

            <div class="input-group">
                <label for="confirmPassword">Confirm Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm new password" required>
            </div>
            
            <button type="submit">Reset Password</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // 1. Backend se aane wale messages ke liye
        const messageType = "<%= typeof messageType !== 'undefined' ? messageType : '' %>";
        const messageText = "<%= typeof messageText !== 'undefined' ? messageText : '' %>";

        const swalConfig = {
            background: '#16161a',
            color: '#ffffff',
            confirmButtonColor: '#7c3aed',
            customClass: { popup: 'gradly-swal-popup' }
        };

        if (messageType) {
            if (messageType === 'success') {
                Swal.fire({
                    ...swalConfig,
                    icon: 'success',
                    title: 'Password Updated!',
                    text: messageText || 'Your password has been reset successfully. You can now login.'
                }).then(() => {
                    // Success ke baad login page par bhej dein
                    window.location.href = '/students/login';
                });
            } else if (messageType === 'error') {
                Swal.fire({
                    ...swalConfig,
                    icon: 'error',
                    title: 'Error!',
                    text: messageText || 'Invalid or expired token. Please try again.',
                    confirmButtonColor: '#ef4444'
                });
            }
        }

        // 2. Client-side Password Match Validation
        document.getElementById('resetForm').addEventListener('submit', function(e) {
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (password !== confirmPassword) {
                // Agar password match nahi karte, toh form submit rok do
                e.preventDefault(); 
                
                // Aur SweetAlert error dikhao
                Swal.fire({
                    ...swalConfig,
                    icon: 'warning',
                    title: 'Passwords do not match!',
                    text: 'Please make sure both passwords are the same.',
                    confirmButtonColor: '#f59e0b'
                });
            }
        });
    </script>
</body>
</html>