<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Profile - Gradly</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="/css/Profile.css">
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="/students">🎓 Gradly</a>
            <div class="ms-auto">
                <a href="/students/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <section class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-10 col-lg-8">

                    <div class="card glass-card p-4 p-md-5">

                        <div class="text-center mb-5">
                            <div class="mb-3">
                                <div class="mb-3 text-center">
                                    <div class="profile-image-box">
                                        <img src="<%= student.image ? student.image : '/uploads/default.png' %>"
                                            alt="Profile Image">
                                    </div>
                                </div>
                            </div>

                            <h2 class="fw-bold">
                                My Profile
                                <% if (student.isAdmin) { %>
                                    <span class="badge bg-warning text-dark ms-2">Admin</span>
                                    <% } %>
                            </h2>

                            <p class="text-muted small">Student Information System</p>
                        </div>

                        <!-- Personal Details -->
                        <h6 class="section-title">Personal Details</h6>
                        <div class="row g-4 mb-4">

                            <div class="col-md-6">
                                <label class="label-custom">First Name</label>
                                <div class="value-custom">
                                    <%= student.firstName %>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="label-custom">Last Name</label>
                                <div class="value-custom">
                                    <%= student.lastName %>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="label-custom">Date of Birth</label>
                                <div class="value-custom">
                                    <%= student.dob ? new Date(student.dob).toDateString() : "N/A" %>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="label-custom">Age</label>
                                <div class="value-custom">
                                    <%= student.age || "N/A" %>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="label-custom">Gender</label>
                                <div class="value-custom">
                                    <%= student.gender || "N/A" %>
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="label-custom">Hobbies</label>
                                <div class="value-custom">
                                    <%= Array.isArray(student.hobbies) ? student.hobbies.join(", ") 
                                    : student.hobbies || " N/A" %>
                                </div>
                            </div>

                        </div>

                        <hr class="divider">

                        <!-- Contact Info -->
                        <h6 class="section-title">Contact Information</h6>
                        <div class="row g-4 mb-4">

                            <div class="col-md-6">
                                <label class="label-custom">Email Address</label>
                                <div class="value-custom">
                                    <%= student.email %>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="label-custom">Phone Number</label>
                                <div class="value-custom">
                                    <%= student.phone || "N/A" %>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="label-custom">Address</label>
                                <div class="value-custom">
                                    <%= student.address || "N/A" %>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="label-custom">Country</label>
                                <div class="value-custom">
                                    <%= student.country || "N/A" %>
                                </div>
                            </div>

                        </div>

                        <hr class="divider">

                        <!-- Identity -->
                        <h6 class="section-title">Identity & Security</h6>
                        <div class="row g-4 mb-5">

                            <div class="col-md-6">
                                <label class="label-custom">PAN Card</label>
                                <div class="value-custom">
                                    <%= student.pan || "N/A" %>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="label-custom">Aadhar Number</label>
                                <div class="value-custom">
                                    <%= student.adhar || "N/A" %>
                                </div>
                            </div>

                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2 col-md-6 mx-auto mb-3">
                            <a href="/students/edit/<%= student._id %>" class="btn btn-danger py-2 fw-bold">
                                Update Profile
                            </a>
                        </div>
                        <% if (!student.isAdmin) { %>
                            <div class="d-grid gap-2 col-md-6 mx-auto">
                                <a href="/students/change-password" class="btn btn-danger py-2 fw-bold">
                                    Change Password
                                </a>
                            </div>
                            <% } %>
                                <!-- Admin Dashboard Button -->
                                <% if (student.isAdmin) { %>
                                    <div class="d-grid gap-2 col-md-6 mx-auto mb-3">
                                        <a href="/students/admin/dashboard" class="btn btn-dark py-2 fw-bold">
                                            Admin Dashboard
                                        </a>
                                    </div>
                                    <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Update Success Alert -->
    <% if (typeof messageType !=='undefined' && messageType==="updateSuccess" ) { %>
        <script>
            Swal.fire({
                icon: "success",
                title: "Profile Updated Successfully!",
                text: "Your changes have been saved.",
                confirmButtonText: "OK",
                confirmButtonColor: "#7b2cbf",
                background: '#19191a',
                color: '#fff'
            }).then(() => {
                window.history.replaceState({}, document.title, "/students/profile");
            });
        </script>
        <% } %>
            <% if (typeof messageType !=='undefined' && messageType==="adminRequired" ) { %>
                <script>
                    Swal.fire({
                        icon: "error",
                        title: "Access Denied",
                        text: "Admin access required!",
                        confirmButtonColor: "#7b2cbf",
                        background: '#19191a',
                        color: '#fff'
                    }).then(() => {
                        window.history.replaceState({}, document.title, "/students/profile");
                    });
                </script>
                <% } %>
                    <% if (typeof messageType !=='undefined' && messageType==="superAdminFailed" ) { %>
                        <script>
                            Swal.fire({
                                icon: "error",
                                title: "Validation Failed",
                                text: "Super admin validation failed!",
                                confirmButtonColor: "#7b2cbf",
                                background: '#19191a',
                                color: '#fff'
                            }).then(() => {
                                window.history.replaceState(null, document.title, "/students/profile");
                            });
                        </script>
                        <% } %>


                            <% if (typeof messageType !=='undefined' && messageType==="DashboardError" ) { %>
                                <script>
                                    Swal.fire({
                                        icon: "error",
                                        title: "Dashboard Error",
                                        text: "Error loading dashboard!",
                                        confirmButtonColor: "#7b2cbf",
                                        background: '#19191a',
                                        color: '#fff'
                                    }).then(() => {
                                        window.history.replaceState(null, document.title, "/students/profile");
                                    });
                                </script>
                                <% } %>

                                    <% if (typeof messageType !=='undefined' && messageType==="Unauthorized" ) { %>
                                        <script>
                                            Swal.fire({
                                                icon: "error",
                                                title: "Unauthorized",
                                                text: "Not authorized to update the profile",
                                                confirmButtonColor: "#7b2cbf",
                                                background: '#19191a',
                                                color: '#fff'
                                            }).then(() => {
                                                window.history.replaceState(null, document.title, "/students/profile");
                                            });
                                        </script>
                                        <% } %>
                                            <% if (typeof messageType !=='undefined' && messageType==="updateError" ) {
                                                %>
                                                <script>
                                                    Swal.fire({
                                                        icon: "error",
                                                        title: "Update error Occured",
                                                        text: "Something goes wrong please try again later",
                                                        confirmButtonColor: "#7b2cbf",
                                                        background: '#19191a',
                                                        color: '#fff'
                                                    }).then(() => {
                                                        window.history.replaceState(null, document.title, "/students/profile");
                                                    });
                                                </script>
                                                <% } %>

                                                    <% if (typeof messageType !=='undefined' &&
                                                        messageType==="ErrorProfilePage" ) { %>
                                                        <script>
                                                            Swal.fire({
                                                                icon: "error",
                                                                title: "Page Not Renderd",
                                                                text: "Error rendering the profile page",
                                                                confirmButtonColor: "#7b2cbf",
                                                                background: '#19191a',
                                                                color: '#fff'
                                                            }).then(() => {
                                                                window.history.replaceState(null, document.title, "/students");
                                                            });
                                                        </script>
                                                        <% } %>




</body>

</html>