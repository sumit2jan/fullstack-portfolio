<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Create Student</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/style1.css">
</head>

<body>

   <nav class="navbar navbar-expand-lg navbar-dark py-3">
        <div class="container">
            <a class="navbar-brand fs-4" href="/students">
                🎓 Gradly
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navMenu">
                <ul class="navbar-nav gap-3 align-items-center">
                    <li class="nav-item">
                        <a class="nav-link text-light" href="/login">Login</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    
                    <% if (locals.success) { %>
                        <div class="alert alert-success text-center">
                            Student Created Successfully! <a href="/students/register">Add another?</a>
                        </div>
                    <% } %>

                    <% if (locals.errors && errors.general) { %>
                        <div class="alert alert-danger text-center">
                            <%= errors.general %>
                        </div>
                    <% } %>

                    <div class="card glass-card p-4 p-md-5">

                        <h2 class="text-center mb-4">Create Student</h2>

                        <form action="/students/register" method="POST">

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">First Name</label>
                                    <input type="text" name="firstName" 
                                           class="form-control <%= locals.errors && errors.firstName ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.firstName ? data.firstName : '' %>">
                                    <% if (locals.errors && errors.firstName) { %>
                                        <div class="invalid-feedback"><%= errors.firstName %></div>
                                    <% } %>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Last Name</label>
                                    <input type="text" name="lastName" 
                                           class="form-control <%= locals.errors && errors.lastName ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.lastName ? data.lastName : '' %>">
                                    <% if (locals.errors && errors.lastName) { %>
                                        <div class="invalid-feedback"><%= errors.lastName %></div>
                                    <% } %>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Email</label>
                                    <input type="email" name="email" 
                                           class="form-control <%= locals.errors && errors.email ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.email ? data.email : '' %>">
                                    <% if (locals.errors && errors.email) { %>
                                        <div class="invalid-feedback"><%= errors.email %></div>
                                    <% } %>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Password</label>
                                    <input type="password" name="password" 
                                           class="form-control <%= locals.errors && errors.password ? 'is-invalid' : '' %>">
                                    <% if (locals.errors && errors.password) { %>
                                        <div class="invalid-feedback"><%= errors.password %></div>
                                    <% } %>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Age</label>
                                    <input type="number" name="age" 
                                           class="form-control <%= locals.errors && errors.age ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.age ? data.age : '' %>">
                                    <% if (locals.errors && errors.age) { %>
                                        <div class="invalid-feedback"><%= errors.age %></div>
                                    <% } %>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Gender</label>
                                    <select name="gender" class="form-select <%= locals.errors && errors.gender ? 'is-invalid' : '' %>">
                                        <option value="">Select</option>
                                        <option value="Male" <%= locals.data && data.gender === 'Male' ? 'selected' : '' %>>Male</option>
                                        <option value="Female" <%= locals.data && data.gender === 'Female' ? 'selected' : '' %>>Female</option>
                                        <option value="Other" <%= locals.data && data.gender === 'Other' ? 'selected' : '' %>>Other</option>
                                    </select>
                                    <% if (locals.errors && errors.gender) { %>
                                        <div class="invalid-feedback"><%= errors.gender %></div>
                                    <% } %>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Phone</label>
                                    <input type="text" name="phone" 
                                           class="form-control <%= locals.errors && errors.phone ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.phone ? data.phone : '' %>">
                                    <% if (locals.errors && errors.phone) { %>
                                        <div class="invalid-feedback"><%= errors.phone %></div>
                                    <% } %>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">PAN</label>
                                    <input type="text" name="pan" 
                                           class="form-control <%= locals.errors && errors.pan ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.pan ? data.pan : '' %>">
                                    <% if (locals.errors && errors.pan) { %>
                                        <div class="invalid-feedback"><%= errors.pan %></div>
                                    <% } %>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Adhar</label>
                                    <input type="text" name="adhar" 
                                           class="form-control <%= locals.errors && errors.adhar ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.adhar ? data.adhar : '' %>">
                                    <% if (locals.errors && errors.adhar) { %>
                                        <div class="invalid-feedback"><%= errors.adhar %></div>
                                    <% } %>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Country</label>
                                    <input type="text" name="country" 
                                           class="form-control <%= locals.errors && errors.country ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.country ? data.country : '' %>">
                                    <% if (locals.errors && errors.country) { %>
                                        <div class="invalid-feedback"><%= errors.country %></div>
                                    <% } %>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Date of Birth</label>
                                    <input type="date" name="dob" 
                                           class="form-control <%= locals.errors && errors.dob ? 'is-invalid' : '' %>"
                                           value="<%= locals.data && data.dob ? data.dob : '' %>">
                                    <% if (locals.errors && errors.dob) { %>
                                        <div class="invalid-feedback"><%= errors.dob %></div>
                                    <% } %>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Address</label>
                                <textarea name="address" rows="3" 
                                          class="form-control <%= locals.errors && errors.address ? 'is-invalid' : '' %>"><%= locals.data && data.address ? data.address : '' %></textarea>
                                <% if (locals.errors && errors.address) { %>
                                    <div class="invalid-feedback"><%= errors.address %></div>
                                <% } %>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Hobbies</label>
                                <input type="text" name="hobbies" 
                                       class="form-control <%= locals.errors && errors.hobbies ? 'is-invalid' : '' %>"
                                       placeholder="Enter hobbies separated by comma (e.g. Cricket, Music, Reading)"
                                       value="<%= locals.data && data.hobbies ? data.hobbies : '' %>">
                                <small class="text-muted">Separate multiple hobbies using comma.</small>
                                <% if (locals.errors && errors.hobbies) { %>
                                    <div class="invalid-feedback"><%= errors.hobbies %></div>
                                <% } %>
                            </div>

                            <div class="text-center">
                                <button type="submit" class="btn btn-primary px-5">
                                    Create Student
                                </button>
                            </div>

                        </form>

                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>